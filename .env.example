# ==========================================
# AQUANTICA PLATFORM - Environment Variables
# ==========================================

# Clerk Authentication (Required)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Database (Required)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aquantica"

# AI Provider (openai, groq, gemini, huggingface, local)
# Options:
#   - local: Free fallback responses (no API needed)
#   - groq: Free tier 20 req/min - https://console.groq.com
#   - gemini: Free tier 15 req/min - https://ai.google.dev
#   - huggingface: Free tier ~1000 req/day - https://huggingface.co/settings/tokens
#   - openai: Paid - https://platform.openai.com
AI_PROVIDER=local

# OpenAI (Optional - expensive, only if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Free AI Alternatives (Choose one, no OpenAI needed)
GROQ_API_KEY=gsk_...          # Get from https://console.groq.com (FREE)
GEMINI_API_KEY=...            # Get from https://ai.google.dev (FREE)
HUGGINGFACE_API_KEY=hf_...    # Get from https://huggingface.co/settings/tokens (FREE)

# Pinecone Vector DB (Optional - only for RAG features)
PINECONE_API_KEY=...
PINECONE_INDEX=aquantica
PINECONE_ENVIRONMENT=us-west-2

# AWS S3 (Required for document storage)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_BUCKET_NAME=aquantica-documents
AWS_REGION=us-east-1

# Webhooks & Notifications (Optional)
WEBHOOK_SECRET=your_webhook_secret
WHATSAPP_API_KEY=...

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:8000
